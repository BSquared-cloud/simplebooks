# Claude Code — files to exclude from context

# Secrets and credentials (never feed to Claude)
.env
.env.*
!.env.example
*.pem
*.key
*.secret
secrets/

# Dependencies (large, auto-generated)
node_modules/
venv/
.venv/
env/
__pycache__/
*.py[cod]
dist/
build/

# Logs and temp output
*.log
logs/
tmp/
temp/

# OS and editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Test and coverage artifacts
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
